# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://finapp:finapp_secret@localhost:5432/finapp?sslmode=disable

# JWT
JWT_SECRET=your_super_secret_key_here_minimum_32_characters
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Pluggy
PLUGGY_CLIENT_ID=your_pluggy_client_id
PLUGGY_CLIENT_SECRET=your_pluggy_client_secret
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_WEBHOOK_SECRET=your_webhook_hmac_secret
